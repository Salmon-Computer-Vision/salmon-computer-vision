# utils/syncing/.env

# The S3 bucket name
BUCKET=<s3_bucket>

# The folder where all the data is saved to
DRIVE=/media/hdd

# Username of this device
USERNAME=username

# The organization ID of the deployment site
ORGID=<orgid>

# The name of the deployment site
SITE_NAME=<site_name>

# Extra flags to pass
# -n means no backup as in the data will not be backed up before being moved to the cloud
#FLAGS=-n
